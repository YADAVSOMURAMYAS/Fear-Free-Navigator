# ============================================================
# fear-free-navigator — environment variables template
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# ── App identity ──────────────────────────────────────────────
APP_NAME=fear-free-navigator
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Bengaluru bounding box ────────────────────────────────────
BENGALURU_BBOX_NORTH=13.0827
BENGALURU_BBOX_SOUTH=12.8340
BENGALURU_BBOX_EAST=77.7200
BENGALURU_BBOX_WEST=77.4601
TARGET_CITY=Bengaluru, Karnataka, India

# ── NASA EarthData (VIIRS night lights) ───────────────────────
# Free account: https://urs.earthdata.nasa.gov/users/new
NASA_EARTHDATA_USER=your_nasa_username
NASA_EARTHDATA_PASS=your_nasa_password

# ── Mapillary API (street view images) ───────────────────────
# Free account: https://www.mapillary.com/signup
# Dashboard → Developers → Create app → Client Token
MAPILLARY_ACCESS_TOKEN=your_mapillary_access_token
MAPILLARY_CLIENT_ID=your_mapillary_client_id
MAPILLARY_CLIENT_SECRET=your_mapillary_client_secret

# ── Google Maps API ───────────────────────────────────────────
# https://console.cloud.google.com/ — enable Maps JS + Directions APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Anthropic Claude API (LLM explainer) ─────────────────────
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Safecity API (optional) ───────────────────────────────────
SAFECITY_API_KEY=your_safecity_key_here
SAFECITY_BASE_URL=https://safecity.in/api/v1

# ── Data paths ────────────────────────────────────────────────
# Download CSVs manually and place at these paths:
#   data/raw/blr_crime_2023.csv  → https://data.opencity.in/dataset/bengaluru-crime-data-2023
#   data/raw/india_road_accidents.csv → https://data.gov.in/catalog/road-accidents-india
CRIME_DATA_PATH=data/raw/blr_crime_2023.csv
ACCIDENTS_DATA_PATH=data/raw/india_road_accidents.csv

# ── Database (PostGIS) ────────────────────────────────────────
DATABASE_URL=postgresql://navigator:navigator123@localhost:5432/navigator_db
POSTGRES_DB=navigator_db
POSTGRES_USER=navigator
POSTGRES_PASSWORD=navigator123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
SCORE_CACHE_TTL_SECONDS=3600
ROUTE_CACHE_TTL_SECONDS=300

# ── FastAPI server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_RELOAD=true

# ── Routing algorithm defaults ────────────────────────────────
ALPHA_DEFAULT=0.7
ALPHA_MIN=0.0
ALPHA_MAX=1.0
LAMP_RADIUS_M=80
SHOP_RADIUS_M=200
POLICE_RADIUS_M=500
BUS_STOP_RADIUS_M=300
CCTV_RADIUS_M=150
CRIME_RADIUS_M=200

# ── ML model settings ─────────────────────────────────────────
MODEL_PATH=ai/ml/artifacts/safety_model.pkl
SHAP_EXPLAINER_PATH=ai/ml/artifacts/shap_explainer.pkl
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
IMAGES_PER_SEGMENT=3

# ── Celery async workers ──────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_TIMEZONE=Asia/Kolkata

# ── Frontend (React) ──────────────────────────────────────────
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_DEFAULT_ALPHA=0.7
REACT_APP_MAP_CENTER_LAT=12.9716
REACT_APP_MAP_CENTER_LON=77.5946
REACT_APP_MAP_DEFAULT_ZOOM=13

# ── Evaluation / benchmarking ─────────────────────────────────
BENCHMARK_ROUTE_PAIRS=50
BENCHMARK_OUTPUT=evaluation/results/benchmark_results.csv
EVAL_METRICS_OUTPUT=ai/ml/artifacts/eval_metrics.json

# ── Overpass API ──────────────────────────────────────────────
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT=180

# ── Paths ─────────────────────────────────────────────────────
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
ARTIFACTS_PATH=ai/ml/artifacts
LOGS_PATH=logs
