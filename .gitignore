# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ── Environment ────────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*
!.env.example

# ── Large data files ───────────────────────────────────────────────────────────
# Keep the entire data directory local-only.
data/
data.zip

# ── Cache directories ───────────────────────────────────────────────────────────
cache/
ingestion/cache/

# ── ML Artifacts ───────────────────────────────────────────────────────────────
# Keep metrics and feature list, ignore large model files
ai/ml/artifacts/*.pkl
ai/ml/artifacts/*.bin
ai/ml/cache/

# Keep these small files
!ai/ml/artifacts/eval_metrics.json
!ai/ml/artifacts/india_eval_metrics.json
!ai/ml/artifacts/feature_cols.json
!ai/ml/artifacts/feature_importance.csv
!ai/ml/artifacts/india_feature_importance.csv
!ai/ml/artifacts/*.png

# ── LLM Cache ──────────────────────────────────────────────────────────────────
ai/llm/cache/

# ── Node / Frontend ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/.pnp
frontend/.pnp.js
frontend/coverage/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/
*.pid

# ── Docker ─────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore volumes
docker-volumes/

# ── Test outputs ───────────────────────────────────────────────────────────────
evaluation/results/*.png
evaluation/results/*.csv
evaluation/results/*.json
!evaluation/results/benchmark_summary.json

# ── Misc ───────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/